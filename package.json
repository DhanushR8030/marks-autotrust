{
  "name": "marks-autotrust",
  "version": "1.0.0",
  "description": "Marks Autotrust - Vehicle Management System",
  "author": "Marks Autotrust",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dist": "npm run build"
  },
  "build": {
    "appId": "com.marksautotrust.app",
    "productName": "Marks Autotrust",
    "directories": {
      "output": "dist_final"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/sqlite3/**"
    ],
    "files": [
      "main.js",
      "preload.js",
      "client/build/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/marks_autotrust.ico",
      "target": {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Marks Autotrust"
    }
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "sqlite3": "^6.0.1"
  }
}
